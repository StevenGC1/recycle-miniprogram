<!--
  pages/index/index.wxml
  ============================================================
  用户端首页（极简下单页）
  设计原则：中老年用户优先，所以页面元素能少则少：
    - 不需要选择垃圾分类
    - 不需要填写重量
    - 只需要：地址 + 时间 + (可选)备注/照片 + 一个大按钮
  另外最上方提供"一键呼叫"按钮，给完全不想用小程序流程的人留一条后路。
============================================================ -->
<view class="container">

  <!-- 如果是扫了商户专属码进来的，显示"熟客刷脸"横幅 -->
  <view wx:if="{{boundMerchantName}}" class="merchant-banner">
    <text>【{{boundMerchantName}}】专属回收服务</text>
  </view>

  <!-- ============ 顶部两个"极简操作"按钮区 ============ -->
  <view class="quick-action-row">
    <view class="quick-btn quick-btn-call" bindtap="onCallPhone">
      <text class="quick-icon">📞</text>
      <text>一键呼叫</text>
    </view>
    <view class="quick-btn quick-btn-photo" bindtap="onChoosePhoto">
      <text class="quick-icon">📷</text>
      <text>拍照下单</text>
    </view>
  </view>

  <!-- ============ 正式下单表单区（给愿意多点两下的用户） ============ -->
  <view class="card">

    <!-- 地址选择：支持微信定位一键导入 -->
    <view class="form-item" bindtap="onChooseAddress">
      <text class="form-label">上门地址</text>
      <view class="flex-row">
        <text class="form-value">{{address || '点击选择/定位地址'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 上门时间：今天/明天 + 上午/下午，做成简单的按钮组，不用日历选择器，降低理解成本 -->
    <view class="form-item">
      <text class="form-label">上门时间</text>
      <view class="time-option-group">
        <view
          wx:for="{{dateOptions}}"
          wx:key="value"
          class="time-option {{selectedDate === item.value ? 'time-option-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectDate"
        >{{item.label}}</view>
      </view>
      <view class="time-option-group mt-20">
        <view
          wx:for="{{periodOptions}}"
          wx:key="value"
          class="time-option {{selectedPeriod === item.value ? 'time-option-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectPeriod"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 备注 + 照片，都是选填，不强制 -->
    <view class="form-item">
      <text class="form-label">备注（选填）</text>
      <input
        class="form-input"
        placeholder="例如：旧纸箱比较多"
        value="{{remark}}"
        bindinput="onRemarkInput"
      />
    </view>

    <view class="form-item" bindtap="onChoosePhoto">
      <text class="form-label">照片（选填）</text>
      <view wx:if="{{!tempPhotoPath}}" class="photo-placeholder">+ 拍照</view>
      <image wx:else class="photo-preview" src="{{tempPhotoPath}}" mode="aspectFill" />
    </view>
  </view>

  <!-- ============ 主操作按钮：立即预约 ============ -->
  <view class="bottom-btn-area">
    <view class="btn-primary" bindtap="onSubmitOrder">立即预约</view>
  </view>

</view>
