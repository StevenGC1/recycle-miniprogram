<!--
  pages/index/index.wxml
  ============================================================
  用户端首页（极简下单页） —— V1.2
  本版本调整：
    1. 照片缩略图从"备注上方"挪到【一键呼叫/拍照下单】按钮下方，
       拍完立刻看得到，最多3张。
    2. 今日回收价只展示精选几项 + 【查看更多 ››】跳转分类详情页。
    3. 地址选择后增加"门牌号/楼层"补充输入，弹窗形式收集。
    4. 新增"未绑定商家"皮肤：隐藏一键呼叫、拍照下单拉满、横幅文案变化。
============================================================ -->
<view class="container">

  <!-- 横幅：绑定商家时显示专属商家名，未绑定时显示通用文案 -->
  <view class="merchant-banner">
    <text wx:if="{{isBound}}">【{{boundMerchantName}}】专属回收服务</text>
    <text wx:else>同城绿色回收大厅（极速上门）</text>
  </view>

  <!-- ============ 顶部"极简操作"按钮区 ============ -->
  <!-- 未绑定商家时隐藏"一键呼叫"（没有专属师傅可呼叫），拍照下单按钮占满整行 -->
  <view class="quick-action-row">
    <view wx:if="{{isBound}}" class="quick-btn quick-btn-call" bindtap="onCallPhone">
      <text class="quick-icon">📞</text>
      <text>一键呼叫</text>
    </view>
    <view class="quick-btn quick-btn-photo {{isBound ? '' : 'quick-btn-full'}}" bindtap="onChoosePhoto">
      <text class="quick-icon">📷</text>
      <text>拍照下单</text>
    </view>
  </view>

  <!-- ============ 照片缩略图区：紧跟在按钮下方，拍完立刻可见，最多3张 ============ -->
  <view wx:if="{{photoList.length > 0}}" class="photo-row">
    <view wx:for="{{photoList}}" wx:key="*this" class="photo-thumb-wrap">
      <image class="photo-thumb" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewPhoto" />
      <view class="photo-delete-mark" data-index="{{index}}" catchtap="onDeletePhoto">×</view>
    </view>
    <!-- 不满3张时，继续显示"+"让用户补拍 -->
    <view wx:if="{{photoList.length < 3}}" class="photo-add-btn" bindtap="onChoosePhoto">
      <text>+</text>
    </view>
  </view>

  <!-- ============ 今日回收价 板块（精选展示 + 查看更多） ============ -->
  <view class="price-board">
    <view class="price-board-title">
      <text>💰 今日回收价</text>
      <view class="price-board-more" bindtap="onViewMorePrice">
        <text class="price-board-source">{{priceSourceText}}</text>
        <text class="more-arrow">查看更多 ››</text>
      </view>
    </view>
    <scroll-view scroll-x class="price-scroll" enable-flex>
      <view wx:for="{{priceList}}" wx:key="name" class="price-item">
        <text class="price-name">{{item.name}}</text>
        <text class="price-value">{{item.price}}元/斤</text>
      </view>
    </scroll-view>
  </view>

  <!-- ============ 正式下单表单区 ============ -->
  <view class="card">

    <view class="form-item" bindtap="onChooseAddress">
      <text class="form-label">上门地址</text>
      <view class="flex-row">
        <text class="form-value">{{address || '点击选择/定位地址'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">上门时间</text>
      <view class="time-option-group">
        <view
          wx:for="{{dateOptions}}"
          wx:key="value"
          class="time-option {{selectedDate === item.value ? 'time-option-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectDate"
        >{{item.label}}</view>
      </view>
      <view class="time-option-group mt-20">
        <view
          wx:for="{{periodOptions}}"
          wx:key="value"
          class="time-option {{selectedPeriod === item.value ? 'time-option-active' : ''}} {{item.disabled ? 'time-option-disabled' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectPeriod"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">快捷标签（可多选）</text>
      <view class="quick-tag-group">
        <view
          wx:for="{{quickTags}}"
          wx:key="value"
          class="quick-tag {{item.active ? 'quick-tag-active' : ''}}"
          data-index="{{index}}"
          bindtap="onToggleTag"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">备注（选填）</text>
      <input
        class="form-input"
        placeholder="例如：旧纸箱比较多"
        value="{{remark}}"
        bindinput="onRemarkInput"
      />
    </view>
  </view>

  <view class="bottom-btn-area">
    <view class="btn-primary" bindtap="onSubmitOrder">立即预约</view>
  </view>

  <view class="float-ball" bindtap="onGoMall">
    <text class="float-ball-icon">🛍️</text>
    <text class="float-ball-text">商城</text>
  </view>

  <!-- ============ 地址补充信息弹窗：定位/选点完成后，弹出让用户补门牌号 ============ -->
  <view wx:if="{{showAddressDetailModal}}" class="modal-mask" catchtap="onCloseAddressModal">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">补充门牌信息</view>
      <view class="modal-sub-tip">{{addressBase}}</view>
      <input
        class="modal-input-full"
        placeholder="请输入楼栋/单元/门牌号，如 3栋2单元502"
        value="{{addressDetail}}"
        bindinput="onAddressDetailInput"
      />
      <view class="modal-btn-row">
        <view class="modal-btn modal-btn-cancel" bindtap="onCloseAddressModal">取消</view>
        <view class="modal-btn modal-btn-confirm" bindtap="onConfirmAddressDetail">确认</view>
      </view>
    </view>
  </view>

</view>
