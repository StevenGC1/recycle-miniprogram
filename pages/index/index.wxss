/* pages/index/index.wxss */

.container {
  padding-bottom: 160rpx; /* 给底部固定按钮留出空间 */
}

/* 熟客刷脸横幅 */
.merchant-banner {
  background-color: #2B9939;
  color: #fff;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 顶部两个极简按钮：一键呼叫 / 拍照下单
   故意做得很大、很显眼，符合"中老年人一看就懂"的设计目标 */
.quick-action-row {
  display: flex;
  flex-direction: row;
  padding: 24rpx 20rpx 0 20rpx;
  gap: 20rpx;
}
.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.quick-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}
.quick-btn-call {
  background-color: #fff3e0;
  color: #ff9800;
}
.quick-btn-photo {
  background-color: #e3f2fd;
  color: #2196f3;
}

/* 表单区 */
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}
.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.form-value {
  font-size: 30rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}
.form-input {
  font-size: 30rpx;
  width: 100%;
}

.time-option-group {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
.time-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  color: #666;
}
.time-option-active {
  border-color: #2B9939;
  background-color: #e8f5e9;
  color: #2B9939;
  font-weight: bold;
}

.photo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 26rpx;
}
.photo-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

/* 底部固定的主操作按钮 */
.bottom-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}
