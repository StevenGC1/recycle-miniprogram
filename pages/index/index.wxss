/* pages/index/index.wxss —— V1.2 */

.container {
  padding-bottom: 160rpx;
  position: relative;
}

.merchant-banner {
  background-color: #2B9939;
  color: #fff;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
}

.quick-action-row {
  display: flex;
  flex-direction: row;
  padding: 24rpx 20rpx 0 20rpx;
  gap: 20rpx;
}
.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}
.quick-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}
.quick-btn-call {
  background-color: #fff3e0;
  color: #ff9800;
}
.quick-btn-photo {
  background-color: #e3f2fd;
  color: #2196f3;
}
/* 未绑定商家时，拍照下单按钮独占整行 */
.quick-btn-full {
  flex: 1;
}

/* ---------- 照片缩略图区（紧跟在按钮下方） ---------- */
.photo-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 20rpx 20rpx 0 20rpx;
}
.photo-thumb-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}
.photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}
.photo-delete-mark {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.photo-add-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ccc;
}

/* ---------- 今日回收价 板块 ---------- */
.price-board {
  margin: 20rpx;
  background-color: #fffaf0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}
.price-board-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #ff9800;
  margin-bottom: 16rpx;
}
.price-board-more {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.price-board-source {
  font-size: 20rpx;
  color: #999;
  font-weight: normal;
}
.more-arrow {
  font-size: 24rpx;
  color: #2B9939;
  font-weight: bold;
  margin-top: 4rpx;
}
.price-scroll {
  white-space: nowrap;
}
.price-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 14rpx 24rpx;
  margin-right: 16rpx;
}
.price-name {
  font-size: 24rpx;
  color: #666;
}
.price-value {
  font-size: 26rpx;
  color: #e64340;
  font-weight: bold;
  margin-top: 6rpx;
}

/* 表单区 */
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}
.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.form-value {
  font-size: 30rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}
.form-input {
  font-size: 30rpx;
  width: 100%;
}

.time-option-group {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
.time-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  color: #666;
}
.time-option-active {
  border-color: #2B9939;
  background-color: #e8f5e9;
  color: #2B9939;
  font-weight: bold;
}
.time-option-disabled {
  color: #ccc;
  background-color: #f9f9f9;
  border-color: #f0f0f0;
}

.quick-tag-group {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}
.quick-tag {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border: 2rpx solid #f5f5f5;
  border-radius: 30rpx;
  padding: 10rpx 22rpx;
}
.quick-tag-active {
  background-color: #e8f5e9;
  border-color: #2B9939;
  color: #2B9939;
  font-weight: bold;
}

.bottom-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.float-ball {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #2B9939;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  z-index: 100;
}
.float-ball-icon {
  font-size: 40rpx;
}
.float-ball-text {
  font-size: 20rpx;
  margin-top: 2rpx;
}

/* ---------- 地址补充信息弹窗 ---------- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
}
.modal-sub-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-input-full {
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}
.modal-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
