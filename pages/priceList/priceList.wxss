/* pages/priceList/priceList.wxss */

.header-tip {
  background-color: #fff;
  padding: 30rpx;
  text-align: center;
}
.header-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}
.header-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}

.category-block {
  background-color: #fff;
  margin-top: 16rpx;
}
.category-title {
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 30rpx;
  background-color: #f5f5f5;
}
.price-row {
  display: flex;
  justify-content: space-between;
  padding: 26rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.price-row:last-child {
  border-bottom: none;
}
.price-row-name {
  font-size: 28rpx;
  color: #333;
}
.price-row-value {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}
