/* pages/mine/mine.wxss */

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}
.nickname {
  font-size: 32rpx;
  font-weight: bold;
}

.cell {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.cell:last-child {
  border-bottom: none;
}
.cell-label {
  font-size: 28rpx;
  color: #333;
}
.cell-value {
  font-size: 28rpx;
  color: #666;
  max-width: 400rpx;
  text-align: right;
}
.points-value {
  color: #ff9800;
  font-weight: bold;
}

.switch-role-card {
  text-align: center;
  color: #2B9939;
  font-weight: bold;
  padding: 30rpx 0;
}
.switch-tip {
  font-size: 22rpx;
  padding-bottom: 10rpx;
}

/* ---------- 投诉与建议弹窗 ---------- */
.complaint-textarea {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.complaint-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ---------- 三端任意门 ---------- */
.anydoor-card {
  padding-bottom: 20rpx;
}
.anydoor-title {
  font-size: 22rpx;
  margin-bottom: 16rpx;
}
.anydoor-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}
.anydoor-btn {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #2B9939;
  border: 2rpx solid #2B9939;
  border-radius: 8rpx;
  padding: 16rpx 0;
}

/* ---------- 联系客服弹窗 ---------- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
}
.service-wechat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
}
.service-wechat-text {
  font-size: 30rpx;
  color: #333;
}
.copy-btn {
  font-size: 24rpx;
  color: #fff;
  background-color: #2B9939;
  padding: 8rpx 24rpx;
  border-radius: 6rpx;
}
.modal-btn-row {
  margin-top: 30rpx;
}
.modal-btn {
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
