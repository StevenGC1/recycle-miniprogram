<!--
  pages/mine/mine.wxml
  ============================================================
  "我的"页面
  内容：我的地址、我的积分、联系客服
  另外放一个"切换至商户端"的入口按钮，
  用于演示"同一个小程序内通过角色判断展示不同功能"的设计。
============================================================ -->
<view class="container">

  <view class="card profile-card">
    <view class="avatar-placeholder">👤</view>
    <view class="mt-20">
      <text class="nickname">{{profile.nickName}}</text>
    </view>
  </view>

  <view class="card">
    <view class="flex-between cell">
      <text class="cell-label">我的地址</text>
      <text class="cell-value">{{profile.myAddress}}</text>
    </view>
    <view class="flex-between cell">
      <text class="cell-label">我的积分</text>
      <text class="cell-value points-value">{{profile.myPoints}} 分</text>
    </view>
    <view class="flex-between cell">
      <text class="cell-label">绑定回收师傅</text>
      <text class="cell-value">{{profile.boundMerchant}}</text>
    </view>
  </view>

  <view class="card">
    <view class="flex-between cell" bindtap="onAddFamily">
      <text class="cell-label">亲友代下（绑定父母地址）</text>
      <text class="arrow">›</text>
    </view>
    <view class="flex-between cell" bindtap="onContactService">
      <text class="cell-label">联系客服</text>
      <text class="arrow">›</text>
    </view>
    <!-- V1.9 新增：申请入驻成为回收商 -->
    <view class="flex-between cell" bindtap="onApplyMerchant">
      <text class="cell-label">📋 申请入驻成为回收商</text>
      <text class="arrow">›</text>
    </view>
    <!-- V2.3 新增：投诉与建议 -->
    <view class="flex-between cell" bindtap="onOpenComplaint">
      <text class="cell-label">💬 投诉与建议</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 联系客服弹窗：微信号可一键复制（wx.showModal原生弹窗不支持复制按钮，所以这里自定义弹窗） -->
  <view wx:if="{{showServiceModal}}" class="modal-mask" catchtap="onCloseServiceModal">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">联系客服</view>
      <view class="service-wechat-row">
        <text class="service-wechat-text">{{customerServiceWechat}}</text>
        <view class="copy-btn" bindtap="onCopyWechat">复制</view>
      </view>
      <view class="modal-btn-row">
        <view class="modal-btn modal-btn-confirm" bindtap="onCloseServiceModal">知道了</view>
      </view>
    </view>
  </view>

  <!-- V1.2 新增：测试开关，方便你切换"已绑定商家/未绑定商家"两种首页皮肤体验 -->
  <view class="card">
    <view class="flex-between cell">
      <text class="cell-label">【测试开关】是否绑定专属商家</text>
      <switch checked="{{isBound}}" color="#2B9939" bindchange="onToggleBound" />
    </view>
    <view class="text-gray switch-tip">关闭后回到首页查看"未绑定商家"的展示效果（隐藏一键呼叫、横幅文案变化）</view>
  </view>

  <!-- V2.3 新增：投诉与建议弹窗 -->
  <view wx:if="{{showComplaintModal}}" class="modal-mask" catchtap="onCloseComplaintModal">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">投诉与建议</view>
      <textarea
        class="complaint-textarea"
        placeholder="请描述您遇到的问题或建议（限200字）"
        maxlength="200"
        value="{{complaintContent}}"
        bindinput="onComplaintInput"
      />
      <view class="complaint-count">{{complaintContent.length}}/200</view>
      <view class="modal-btn-row">
        <view class="modal-btn modal-btn-cancel" bindtap="onCloseComplaintModal">取消</view>
        <view class="modal-btn modal-btn-confirm" bindtap="onSubmitComplaint">确认发送</view>
      </view>
    </view>
  </view>

  <!-- ============ V2.3：测试专用"三端任意门" ============ -->
  <!-- 真实上线后不会有这个组件，仅用于你开发阶段在三个身份间无缝切换调试 -->
  <view class="card anydoor-card">
    <view class="anydoor-title text-gray">🚪 [测试用] 任意门 · 快速切换身份</view>
    <view class="anydoor-row">
      <view class="anydoor-btn" bindtap="onGoResident">👤 普通居民</view>
      <view class="anydoor-btn" bindtap="onForceApproveAndEnter">🚲 回收小哥</view>
      <view class="anydoor-btn" bindtap="onGoAdmin">🖥 平台总裁</view>
    </view>
  </view>

</view>
