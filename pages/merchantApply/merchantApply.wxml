<!--
  pages/merchantApply/merchantApply.wxml —— V2.3
  ============================================================
  申请成为回收商 - 完整表单版
  字段：网点/店铺名称、负责人姓名、联系电话(支持一键导入微信手机号)、
        回收常驻网点坐标(地图选点)、车辆/网点照片(1张)
  提交后用 wx.redirectTo 跳转到独立的"审核中"结果页，且无法返回这个表单
  （redirectTo 会关闭当前页面，不会留在页面栈里，用户没法用左上角返回按钮回到表单）
============================================================ -->
<view class="container">

  <!-- 如果已经是 approved/pending/rejected，直接跳走，这里不会显示表单（逻辑在 .js 的 onLoad 里处理） -->
  <view class="card">
    <view class="form-item">
      <text class="form-label">网点/店铺名称</text>
      <input class="form-input" placeholder="请输入您的回收站名称或个人秤名称" value="{{shopName}}" bindinput="onShopNameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">负责人姓名</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{contactName}}" bindinput="onContactNameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">联系电话</text>
      <view class="phone-row">
        <input class="form-input phone-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
        <button class="quick-import-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">一键导入</button>
      </view>
    </view>

    <!-- 回收常驻网点坐标：通栏卡片，点击调用地图选点 -->
    <view class="form-item location-card" bindtap="onChooseLocation">
      <text class="form-label">回收常驻网点/坐标</text>
      <view class="flex-row">
        <text class="form-value">{{locationName || '点击在地图上选择网点位置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 车辆/网点照片：1张，可删除重拍 -->
    <view class="form-item">
      <text class="form-label">车辆/网点照片</text>
      <view class="text-gray photo-tip">请拍摄您的回收三轮车、货车或实体网点照片</view>
      <view class="photo-row mt-20">
        <view wx:if="{{photoPath}}" class="photo-thumb-wrap">
          <image class="photo-thumb" src="{{photoPath}}" mode="aspectFill" />
          <view class="photo-delete-mark" catchtap="onDeletePhoto">×</view>
        </view>
        <view wx:else class="photo-add-btn" bindtap="onChoosePhoto">+</view>
      </view>
    </view>
  </view>

  <view class="bottom-btn-area">
    <view class="btn-primary {{isSubmitting ? 'btn-disabled' : ''}}" bindtap="onSubmitApply">
      {{isSubmitting ? '提交中...' : '提交入驻申请'}}
    </view>
  </view>

</view>
