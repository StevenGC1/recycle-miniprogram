/* pages/merchantApply/merchantApply.wxss —— V2.3 */

.container {
  padding-bottom: 160rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}
.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.form-input {
  font-size: 30rpx;
  width: 100%;
}
.form-value {
  font-size: 30rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.phone-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}
.phone-input {
  flex: 1;
}
.quick-import-btn {
  font-size: 22rpx;
  background-color: #e8f5e9;
  color: #2B9939;
  border-radius: 6rpx;
  padding: 0 20rpx;
  line-height: 2.4;
  margin: 0;
}

.photo-tip {
  font-size: 22rpx;
}
.photo-row {
  display: flex;
  flex-direction: row;
}
.photo-thumb-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.photo-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}
.photo-delete-mark {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.photo-add-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ccc;
}

.bottom-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}
.btn-disabled {
  background-color: #ccc !important;
}
