/* pages/merchant/mine/mine.wxss */

.dashboard-card {
  display: flex;
  flex-direction: row;
}
.dashboard-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.dashboard-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #2B9939;
}
.dashboard-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.tool-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.tool-item:last-child {
  border-bottom: none;
}
.tool-item-no-border {
  text-align: center;
  padding: 10rpx 0;
}
.tool-label {
  font-size: 28rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* 地推码弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
  text-align: center;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.code-placeholder {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto;
  background-color: #f5f5f5;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
}
.code-icon {
  font-size: 120rpx;
}
.code-text {
  font-size: 24rpx;
  color: #666;
}
.code-desc {
  font-size: 22rpx;
  color: #999;
  padding: 0 10rpx;
}
.modal-btn-row {
  margin-top: 30rpx;
}
.modal-btn {
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
