/* pages/merchant/shop/shop.wxss */

.publish-btn-row {
  padding: 24rpx 20rpx 0 20rpx;
}
.publish-btn {
  padding: 24rpx 0;
  font-size: 30rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 26rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
}
.item-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  color: #333;
}
.action-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}

/* ---------- 发布弹窗 ---------- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 640rpx;
  max-height: 85vh;
  overflow-y: auto;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}
.form-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}
.form-input {
  font-size: 28rpx;
  width: 100%;
}
.photo-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}
.photo-thumb-wrap {
  width: 120rpx;
  height: 120rpx;
}
.photo-thumb-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}
.photo-add-btn-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ccc;
}
.modal-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
