/* pages/merchant/index/index.wxss */

.container {
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  padding: 24rpx 30rpx 0 30rpx;
  color: #333;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 26rpx;
}

.community-name {
  font-size: 32rpx;
  font-weight: bold;
}
.order-line {
  font-size: 28rpx;
  color: #333;
}

.grab-row {
  display: flex;
}
.grab-btn {
  flex: 1;
  padding: 18rpx 0;
  font-size: 30rpx;
}

/* 子tab：待上门/已完成/已取消 */
.sub-tab-bar {
  display: flex;
  flex-direction: row;
  margin: 20rpx 20rpx 0 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.sub-tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
}
.sub-tab-active {
  color: #2B9939;
  font-weight: bold;
  background-color: #e8f5e9;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 18rpx 0;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  color: #333;
}
.action-btn-confirm {
  background-color: #2B9939;
  color: #fff;
  font-weight: bold;
}

.done-info {
  background-color: #e8f5e9;
  color: #2B9939;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 8rpx;
}
.rating-info {
  background-color: #fff8e1;
  border-radius: 8rpx;
  padding: 16rpx;
}
.rating-stars {
  color: #ffc107;
  font-size: 28rpx;
  margin-right: 8rpx;
}
.rating-text {
  font-size: 24rpx;
  color: #666;
}

.bottom-nav {
  display: flex;
  flex-direction: row;
  background-color: #fff;
  margin-top: 40rpx;
  padding: 24rpx 0;
}
.bottom-nav-item {
  flex: 1;
  text-align: center;
  color: #2B9939;
  font-size: 28rpx;
  font-weight: bold;
  border-right: 1rpx solid #f0f0f0;
}
.bottom-nav-item:last-child {
  border-right: none;
}

/* 称重结算弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.modal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.modal-label {
  font-size: 26rpx;
  color: #666;
}
.modal-input {
  text-align: right;
  font-size: 28rpx;
  width: 200rpx;
}
.modal-points {
  color: #ff9800;
  font-weight: bold;
}
.modal-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
