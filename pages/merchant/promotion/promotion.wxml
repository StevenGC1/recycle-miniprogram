<!--
  pages/merchant/promotion/promotion.wxml
  ============================================================
  商户端 - 推广中心
  展示"专属推广码"（原型阶段用文字+占位图代替真实二维码）
  以及已绑定客户数统计，对应方案里"利益绑定/区域裂变"的核心策略。
============================================================ -->
<view class="container">

  <view class="card code-card">
    <view class="code-placeholder">
      <text class="code-icon">🔲</text>
    </view>
    <view class="mt-20 code-text">推广码内容：{{profile.promotionCode}}</view>
    <view class="mt-20 code-desc">居民扫描此码进入小程序后，将自动显示"{{profile.merchantName}}专属回收服务"</view>
    <view class="btn-primary mt-40" bindtap="onSaveCode">保存推广码图片</view>
  </view>

  <view class="card stat-card">
    <view class="stat-item">
      <text class="stat-num">{{profile.boundResidentCount}}</text>
      <text class="stat-label">已绑定客户数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{profile.totalOrders}}</text>
      <text class="stat-label">累计完成订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{profile.serviceYears}}</text>
      <text class="stat-label">从业年限</text>
    </view>
  </view>

</view>
