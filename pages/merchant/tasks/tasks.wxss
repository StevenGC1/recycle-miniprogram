/* pages/merchant/tasks/tasks.wxss */

.empty-tip {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 28rpx;
}

.community-name {
  font-size: 32rpx;
  font-weight: bold;
}

.order-line {
  font-size: 28rpx;
  color: #333;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 18rpx 0;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  color: #333;
}
.action-btn-confirm {
  background-color: #2B9939;
  color: #fff;
  font-weight: bold;
}

.done-info {
  background-color: #e8f5e9;
  color: #2B9939;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 8rpx;
}

/* ---------- 记账弹窗 ---------- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.modal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.modal-label {
  font-size: 26rpx;
  color: #666;
}
.modal-input {
  text-align: right;
  font-size: 28rpx;
  width: 200rpx;
}
.modal-points {
  color: #ff9800;
  font-weight: bold;
}
.modal-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
