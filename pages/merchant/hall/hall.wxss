/* pages/merchant/hall/hall.wxss */

.merchant-header {
  padding: 24rpx 30rpx;
  color: #666;
  font-size: 26rpx;
  background-color: #fff;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 28rpx;
}

.community-name {
  font-size: 32rpx;
  font-weight: bold;
}

.order-line {
  font-size: 28rpx;
  color: #333;
}

.grab-row {
  display: flex;
}
.grab-btn {
  flex: 1;
  padding: 18rpx 0;
  font-size: 30rpx;
}

/* 底部三个二级入口（因为不在 tabBar 里，所以做一个简单的底部导航条） */
.bottom-nav {
  display: flex;
  flex-direction: row;
  background-color: #fff;
  margin-top: 40rpx;
  padding: 24rpx 0;
  position: sticky;
  bottom: 0;
}
.bottom-nav-item {
  flex: 1;
  text-align: center;
  color: #2B9939;
  font-size: 28rpx;
  border-right: 1rpx solid #f0f0f0;
}
.bottom-nav-item:last-child {
  border-right: none;
  color: #999;
}
