/* pages/merchant/priceConfig/priceConfig.wxss */

.container {
  padding-bottom: 160rpx;
}

.tip-bar {
  background-color: #fff8e1;
  color: #ff9800;
  font-size: 24rpx;
  padding: 20rpx 30rpx;
}

.category-block {
  background-color: #fff;
  margin-top: 16rpx;
}
.category-title {
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 30rpx;
  background-color: #f5f5f5;
}
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.price-row:last-child {
  border-bottom: none;
}
.price-row-name {
  font-size: 28rpx;
  color: #333;
}
.price-edit-area {
  display: flex;
  align-items: center;
}
.price-input {
  width: 120rpx;
  text-align: right;
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
  border-bottom: 2rpx solid #e0e0e0;
}
.price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.bottom-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}
