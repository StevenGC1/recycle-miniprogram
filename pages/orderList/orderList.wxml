<!--
  pages/orderList/orderList.wxml
  ============================================================
  用户端订单列表页
  展示：待接单 / 待上门 / 已完成 三种状态
  动作：未接单前可以取消订单
============================================================ -->
<view class="container">

  <!-- 顶部状态筛选 tab -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{currentTab === item.value ? 'tab-item-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onSwitchTab"
    >{{item.label}}</view>
  </view>

  <!-- 订单卡片列表 -->
  <view wx:if="{{filteredOrders.length === 0}}" class="empty-tip">暂无相关订单</view>

  <view wx:for="{{filteredOrders}}" wx:key="orderId" class="card">
    <view class="flex-between">
      <text class="order-id text-gray">订单号：{{item.orderId}}</text>
      <text class="tag {{item.statusTagClass}}">{{item.statusText}}</text>
    </view>

    <view class="mt-20">
      <text class="order-line">📍 {{item.fullAddress}}</text>
    </view>
    <view class="mt-20">
      <text class="order-line">🕒 {{item.appointmentTime}}</text>
    </view>
    <view wx:if="{{item.remark}}" class="mt-20">
      <text class="order-line text-gray">备注：{{item.remark}}</text>
    </view>
    <view wx:if="{{item.merchantName}}" class="mt-20">
      <text class="order-line">回收师傅：{{item.merchantName}}</text>
    </view>
    <view wx:if="{{item.status === 'done'}}" class="mt-20">
      <text class="order-line">本次回收：{{item.weight}} 斤，获得积分 +{{item.pointsEarned}}</text>
    </view>

    <!-- 只有"待接单"状态才能取消 -->
    <view wx:if="{{item.status === 'wait'}}" class="mt-20 cancel-row">
      <view class="btn-danger" data-id="{{item.orderId}}" bindtap="onCancelOrder">取消订单</view>
    </view>
  </view>

</view>
