/* pages/orderList/orderList.wxss */

.tab-bar {
  display: flex;
  flex-direction: row;
  background-color: #fff;
  padding: 0 20rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item-active {
  color: #2B9939;
  font-weight: bold;
}
.tab-item-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #2B9939;
  border-radius: 4rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 28rpx;
}

.order-line {
  font-size: 28rpx;
  color: #333;
}

.cancel-row {
  display: flex;
  justify-content: flex-end;
}
