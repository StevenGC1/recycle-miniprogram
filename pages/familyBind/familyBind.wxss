/* pages/familyBind/familyBind.wxss */

.container {
  padding-bottom: 160rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}
.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}
.form-value {
  font-size: 30rpx;
  color: #333;
}
.form-input {
  font-size: 30rpx;
  width: 100%;
}
.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.bottom-btn-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.list-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.family-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.family-item:last-child {
  border-bottom: none;
}
.family-name {
  font-size: 28rpx;
  font-weight: bold;
}
.book-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
}

/* ---------- 地址补充信息弹窗（与首页一致） ---------- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
}
.modal-sub-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-input-full {
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}
.modal-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 30rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}
.modal-btn-confirm {
  background-color: #2B9939;
  color: #fff;
}
